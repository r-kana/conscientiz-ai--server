{
  "name": "concientiza-ai_server",
  "version": "1.0.0",
  "description": "servidor do projeto conscientizAI",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "imports": {
    "#/*": "./dist/*",
    "#/env/*": "./dist/config/env/*"
  },
  "scripts": {
    "clean": "rimraf dist build",
    "prebuild": "npm run clean",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run prebuild && tsc",
    "start:tsx:watch": "tsx watch --env-file=.env src/server.ts",
    "start:dev": "run-s start:tsx:watch",
    "db:migrate": "npx sequelize-cli db:migrate"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/validator": "^13.15.10",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "sequelize-cli": "^6.6.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}