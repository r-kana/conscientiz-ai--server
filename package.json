{
  "name": "concientiza-ai_server",
  "version": "1.0.0",
  "description": "servidor do projeto conscientizAI",
  "license": "ISC",
  "author": "Rafael Kanazawa",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf dist build",
    "prebuild": "npm run clean",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run prebuild && npm run build:tsdown",
    "build:tsdown": "tsdown --config ./tsdown.config.ts",
    "start:tsx:watch": "tsx watch --env-file=.env src/server.ts",
    "start:dev": "run-s start:tsx:watch",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:deploy": "NODE_ENV=production npx sequelize-cli db:migrate --debug && NODE_ENV=production npx sequelize-cli db:seed:all --debug",
    "build:prod": "pnpm install --frozen-lockfile && pnpm db:deploy && pnpm build",
    "start:prod": "node --env-file=.env --enable-source-maps dist/server.mjs",
    "db:dev:reset": "rm src/db/development.sqlite && npx sequelize-cli db:migrate --debug && npx sequelize-cli db:seed:all --debug",
    "combo": "pnpm i && docker compose down -v && docker compose up -d --force-recreate && pnpm start:dev"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "9.1.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/validator": "^13.15.10",
    "npm-run-all": "^4.1.5",
    "sequelize-cli": "^6.6.5",
    "tsdown": "^0.21.10",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.34.4+sha512.8768be55200ae3f2226b6527fcca2687e14bc4e5f12d7721a0f25da3df47915177058648db4177baf348120fa0ba2752d8d8d93f6beaf1fe64ae18da8de961af"
}
